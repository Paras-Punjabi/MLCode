{
  "name": "api-gateway",
  "version": "0.0.1",
  "description": "API Gateway for ML Code platform with auth service",
  "scripts": {
    "start": "tsx src/app.ts",
    "dev": "tsx watch src/app.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "drizzle-kit generate --config ./src/configs/drizzle.config",
    "db:migrate": "drizzle-kit migrate --config ./src/configs/drizzle.config",
    "db:push": "drizzle-kit push --config ./src/configs/drizzle.config.ts"
  },
  "author": "ML Code",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^1.7.33",
    "@types/express": "^5.0.3",
    "@types/node": "^22.18.8",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "express-winston": "^4.2.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
